# ─── Category Display Names ─────────────────────────────────────────────────
# Compatible with bash 3.x (macOS default) - no associative arrays
get_category_name() {
  case "$1" in
    frontend) echo "Frontend" ;;
    backend) echo "Backend" ;;
    fullstack) echo "Fullstack" ;;
    mobile) echo "Mobile" ;;
    desktop) echo "Desktop" ;;
    cli-library) echo "CLI / Library / Tooling" ;;
    ai-ml) echo "AI / ML" ;;
    monorepo) echo "Monorepo" ;;
    infrastructure) echo "Infrastructure / DevOps" ;;
    serverless) echo "Serverless / Edge" ;;
    cms-admin) echo "CMS / Admin" ;;
    ecommerce) echo "E-commerce" ;;
    realtime) echo "Real-time / Bots" ;;
    documentation) echo "Documentation / Content" ;;
    email) echo "Email" ;;
    microservices) echo "Microservices" ;;
    web3) echo "Web3 / Blockchain" ;;
    landing) echo "Landing / Marketing" ;;
    testing) echo "Testing / QA" ;;
    *) echo "$1" ;;
  esac
}

# Category order for display
CATEGORY_ORDER=(
  frontend backend fullstack mobile desktop cli-library ai-ml monorepo
  infrastructure serverless cms-admin ecommerce realtime documentation
  email microservices web3 landing testing
)

# ─── Functions ───────────────────────────────────────────────────────────────

show_version() {
  echo -e "${BOLD}mh${NC} v${VERSION}"
}

show_help() {
  header "monorepo-helper (mh) v${VERSION}"
  echo ""
  echo -e "${BOLD}USAGE${NC}"
  echo "  mh <command> [options]"
  echo ""
  echo -e "${BOLD}COMMANDS${NC}"
  echo -e "  ${GREEN}generate${NC} <template> [name]  Generate a new project from template"
  echo -e "  ${GREEN}list${NC} [category]             List available templates"
  echo -e "  ${GREEN}search${NC} <query>              Search templates by keyword"
  echo -e "  ${GREEN}info${NC} <template>             Show template details"
  echo -e "  ${GREEN}version${NC}                     Show version"
  echo -e "  ${GREEN}help${NC}                        Show this help"
  echo ""
  echo -e "${BOLD}OPTIONS${NC}"
  echo "  --name, -n <name>          Project name (default: template default)"
  echo "  --help, -h                 Show help"
  echo ""
  echo -e "${BOLD}EXAMPLES${NC}"
  echo "  mh generate next-app my-website"
  echo "  mh generate node-express --name my-api"
  echo "  mh generate turbo-next-nest"
  echo "  mh list frontend"
  echo "  mh search react"
  echo ""
}

# List templates, optionally filtered by category
cmd_list() {
  local filter="${1:-}"

  if [[ -n "$filter" ]]; then
    # Show single category
    local display_name
    display_name="$(get_category_name "$filter")"
    echo ""
    echo -e "${BOLD}${MAGENTA}${display_name}${NC}"
    echo -e "${GRAY}$(printf '─%.0s' $(seq 1 50))${NC}"
    for entry in "${TEMPLATES[@]}"; do
      IFS=':' read -r cat tmpl desc <<< "$entry"
      if [[ "$cat" == "$filter" ]]; then
        echo -e "  ${GREEN}${tmpl}${NC}  ${DIM}${desc}${NC}"
      fi
    done
    echo ""
  else
    # Show all categories
    header "Available Templates"
    for cat in "${CATEGORY_ORDER[@]}"; do
      local display_name
      display_name="$(get_category_name "$cat")"
      local count=0
      for entry in "${TEMPLATES[@]}"; do
        IFS=':' read -r c _ _ <<< "$entry"
        [[ "$c" == "$cat" ]] && count=$((count + 1))
      done
      echo ""
      echo -e "  ${BOLD}${MAGENTA}${display_name}${NC} ${GRAY}(${count})${NC}"
      for entry in "${TEMPLATES[@]}"; do
        IFS=':' read -r c tmpl desc <<< "$entry"
        if [[ "$c" == "$cat" ]]; then
          echo -e "    ${GREEN}${tmpl}${NC}  ${DIM}${desc}${NC}"
        fi
      done
    done
    echo ""
    local total=${#TEMPLATES[@]}
    echo -e "  ${BOLD}Total: ${total} templates${NC}"
    echo ""
  fi
}

# Search templates by keyword
cmd_search() {
  local query="${1:-}"
  if [[ -z "$query" ]]; then
    error "Please provide a search query."
    echo "  Usage: mh search <query>"
    exit 1
  fi

  local found=0
  echo ""
  echo -e "${BOLD}Search results for '${query}':${NC}"
  echo ""

  for entry in "${TEMPLATES[@]}"; do
    IFS=':' read -r cat tmpl desc <<< "$entry"
    if echo "${cat}:${tmpl}:${desc}" | grep -qi "$query"; then
      local display_name
      display_name="$(get_category_name "$cat")"
      echo -e "  ${GREEN}${tmpl}${NC} ${GRAY}[${display_name}]${NC}"
      echo -e "  ${DIM}${desc}${NC}"
      echo ""
      found=$((found + 1))
    fi
  done

  if [[ $found -eq 0 ]]; then
    warn "No templates found matching '${query}'"
  else
    echo -e "  ${BOLD}Found: ${found} template(s)${NC}"
  fi
  echo ""
}

# Show info about a specific template
cmd_info() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    error "Please provide a template name."
    echo "  Usage: mh info <template>"
    exit 1
  fi

  for entry in "${TEMPLATES[@]}"; do
    IFS=':' read -r cat tmpl desc <<< "$entry"
    if [[ "$tmpl" == "$target" ]]; then
      local display_name
      display_name="$(get_category_name "$cat")"
      echo ""
      header "${tmpl}"
      echo ""
      echo -e "  ${BOLD}Category:${NC}    ${display_name}"
      echo -e "  ${BOLD}Stack:${NC}       ${desc}"
      echo -e "  ${BOLD}Template:${NC}    templates/${cat}/${tmpl}.sh"
      echo ""
      echo -e "  ${BOLD}Usage:${NC}"
      echo -e "    mh generate ${tmpl} [project-name]"
      echo ""
      return
    fi
  done

  error "Template '${target}' not found."
  echo "  Run 'mh list' to see available templates."
  exit 1
}

# Generate a project from template
cmd_generate() {
  local template="${1:-}"
  if [[ -z "$template" ]]; then
    error "Please provide a template name."
    echo "  Usage: mh generate <template> [project-name]"
    echo "  Run 'mh list' to see available templates."
    exit 1
  fi
  shift

  # Find the template
  local found_cat=""
  for entry in "${TEMPLATES[@]}"; do
    IFS=':' read -r cat tmpl desc <<< "$entry"
    if [[ "$tmpl" == "$template" ]]; then
      found_cat="$cat"
      break
    fi
  done

  if [[ -z "$found_cat" ]]; then
    error "Template '${template}' not found."
    echo ""
    # Suggest similar templates
    local suggestions=()
    for entry in "${TEMPLATES[@]}"; do
      IFS=':' read -r _ tmpl _ <<< "$entry"
      if echo "$tmpl" | grep -qi "${template:0:4}"; then
        suggestions+=("$tmpl")
      fi
    done
    if [[ ${#suggestions[@]} -gt 0 ]]; then
      echo -e "  ${YELLOW}Did you mean:${NC}"
      for s in "${suggestions[@]}"; do
        echo -e "    ${GREEN}${s}${NC}"
      done
    fi
    echo ""
    echo "  Run 'mh list' to see all available templates."
    exit 1
  fi

  local script_path="${MH_ROOT}/templates/${found_cat}/${template}.sh"
  if [[ ! -f "$script_path" ]]; then
    error "Template script not found: ${script_path}"
    echo "  This template has not been implemented yet."
    exit 1
  fi

  echo ""
  header "Generating: ${template}"
  echo ""

  # Execute template script with remaining args
  bash "$script_path" "$@"
}

# ─── Main ────────────────────────────────────────────────────────────────────

main() {
  local command="${1:-help}"

  case "$command" in
    generate|g|new|create)
      shift
      cmd_generate "$@"
      ;;
    list|ls|l)
      shift
      cmd_list "$@"
      ;;
    search|s|find)
      shift
      cmd_search "$@"
      ;;
    info|i)
      shift
      cmd_info "$@"
      ;;
    version|--version|-v)
      show_version
      ;;
    help|--help|-h)
      show_help
      ;;
    *)
      # Try as template name directly: mh next-app my-project
      for entry in "${TEMPLATES[@]}"; do
        IFS=':' read -r _ tmpl _ <<< "$entry"
        if [[ "$tmpl" == "$command" ]]; then
          shift
          cmd_generate "$command" "$@"
          return
        fi
      done
      error "Unknown command: ${command}"
      echo "  Run 'mh help' for usage."
      exit 1
      ;;
  esac
}

main "$@"
