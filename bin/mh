# Resolve symlinks and find the real script location
SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
if [[ -L "$SELF" ]]; then
  SELF="$(readlink -f "$SELF" 2>/dev/null || readlink "$SELF")"
fi
MH_ROOT="$(cd "$(dirname "$SELF")/.." && pwd)"

source "${MH_ROOT}/lib/colors.sh"

VERSION="1.0.0"

